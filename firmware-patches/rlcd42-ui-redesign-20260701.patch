+    lv_obj_set_style_text_font(alert_msg_lbl_, big_font, 0);        // 30px common 全字集
+    lv_obj_set_style_text_color(alert_msg_lbl_, white, 0);
+    lv_obj_set_style_text_align(alert_msg_lbl_, LV_TEXT_ALIGN_CENTER, 0);
