+
+// 1s tick：切待命屏显隐；idle 时刷时间(每分变)/日期/温湿度(30s)/电池(30s)/wifi。
+// 反射屏每次刷新都整屏推 SPI，故所有 set_text 都先比对缓存，值没变就不动→不触发 flush。
+void CustomLcdDisplay::UpdateIdleScreen() {
+    if (idle_screen_ == nullptr) {
+        return;
+    }
+    bool idle = (Application::GetInstance().GetDeviceState() == kDeviceStateIdle);
+    if (idle != idle_visible_) {
+        idle_visible_ = idle;
+        if (idle) {
+            lv_obj_remove_flag(idle_screen_, LV_OBJ_FLAG_HIDDEN);
+            idle_env_tick_ = 0;   // 进 idle 立刻读一次温湿度/电池
+        } else {
+            lv_obj_add_flag(idle_screen_, LV_OBJ_FLAG_HIDDEN);
+            if (alert_screen_ != nullptr) {   // 唤醒 → 顺手撤掉提醒接管屏
+                lv_obj_add_flag(alert_screen_, LV_OBJ_FLAG_HIDDEN);
+                if (alert_screen_timer_ != nullptr) lv_timer_pause(alert_screen_timer_);
+            }
+        }
+    }
+    // ---- wifi + 电池：idle 屏和对话顶条两套都刷（隐藏的那套不绘制、开销忽略；保证切换时不残旧）----
+    // wifi 信号格(每秒)：GetNetworkStateIcon 字形 → 0-3 格（满格/一般/弱→3/2/1）
+    const char* wifi = Board::GetInstance().GetNetworkStateIcon();
+    int wlvl;
+    if (wifi == nullptr)                                wlvl = 0;
+    else if (strcmp(wifi, FONT_AWESOME_WIFI) == 0)      wlvl = 3;
+    else if (strcmp(wifi, FONT_AWESOME_WIFI_FAIR) == 0) wlvl = 2;
+    else if (strcmp(wifi, FONT_AWESOME_WIFI_WEAK) == 0) wlvl = 1;
+    else                                                wlvl = 0;   // slash/未连
+    if (wlvl != last_wifi_lvl_) {
+        last_wifi_lvl_ = wlvl;
+        SetSignalBars(idle_wifi_bars_, wlvl);
+        SetSignalBars(conv_wifi_bars_, wlvl);
+    }
+    // 电池(每 ~30s，ADC 有噪)：两套填充按电量
+    if (idle_env_tick_ == 0) {
+        int lvl = 0; bool chg = false, dis = false;
+        if (Board::GetInstance().GetBatteryLevel(lvl, chg, dis) && lvl != last_bat_pct_) {
+            last_bat_pct_ = lvl;
+            SetBatFill(idle_bat_fill_, lvl);
+            SetBatFill(conv_bat_fill_, lvl);
+        }
+    }
+
+    // ---- 以下仅 idle 屏：时钟/日期/温湿度（对话态跳过）----
+    if (idle) {
+        // 中文标签换 common 全字集（basic 子集缺「周/湿/度/°」）；assets 此刻已就绪。
+        if (!idle_font_applied_) {
+            const lv_font_t* cf = CommonFont16();
+            const lv_font_t* cf20 = CommonFont20();
+            if (cf != nullptr && cf20 != nullptr) {
+                lv_obj_t* labels[] = {idle_title_label_, idle_date_label_, idle_env_label_};
+                for (auto l : labels) {
+                    if (l != nullptr) {
+                        lv_obj_set_style_text_font(l, cf, 0);
+                    }
+                }
+                lv_obj_t* ag[] = {idle_rem_lbl_, idle_rem_body_, idle_todo_lbl_, idle_todo_body_};
+                for (auto l : ag) {   // 议程提醒/待办用更大的 20px common
+                    if (l != nullptr) lv_obj_set_style_text_font(l, cf20, 0);
+                }
+                idle_font_applied_ = true;
+            }
+        }
+
+        time_t now = time(nullptr);
+        struct tm tmv;
+        localtime_r(&now, &tmv);
+        bool time_ok = (tmv.tm_year >= 2025 - 1900);
+
+        char tbuf[8];
+        if (time_ok) {
+            snprintf(tbuf, sizeof(tbuf), "%02d:%02d", tmv.tm_hour, tmv.tm_min);
+        } else {
+            snprintf(tbuf, sizeof(tbuf), "--:--");
+        }
+        if (strcmp(tbuf, idle_last_time_) != 0) {
+            strncpy(idle_last_time_, tbuf, sizeof(idle_last_time_) - 1);
+            lv_label_set_text(idle_time_label_, tbuf);
+        }
+
+        static const char* const WD[] = {"周日", "周一", "周二", "周三", "周四", "周五", "周六"};
+        char dbuf[40];
+        if (time_ok) {
+            snprintf(dbuf, sizeof(dbuf), "%d月%d日 %s", tmv.tm_mon + 1, tmv.tm_mday, WD[tmv.tm_wday]);
+        } else {
+            dbuf[0] = '\0';
+        }
+        if (strcmp(dbuf, idle_last_date_) != 0) {
+            strncpy(idle_last_date_, dbuf, sizeof(idle_last_date_) - 1);
+            lv_label_set_text(idle_date_label_, dbuf);
+        }
+
+        // 温湿度：30s 刷一次；首次读到前每秒重试（开机 codec 抢 I2C，前几次会失败，别干等 30s）
+        if (idle_env_tick_ == 0 || !idle_env_ok_) {
+            float t = 0, h = 0;
+            if (ReadShtc3(t, h)) {
+                idle_env_ok_ = true;
+                char ebuf[40];
+                snprintf(ebuf, sizeof(ebuf), "%.1f°C  湿度%.0f%%", (double)t, (double)h);
+                if (strcmp(ebuf, idle_last_env_) != 0) {
+                    strncpy(idle_last_env_, ebuf, sizeof(idle_last_env_) - 1);
+                    lv_label_set_text(idle_env_label_, ebuf);
+                }
+            }
+        }
+    }
+    idle_env_tick_ = (idle_env_tick_ + 1) % 30;
+}
+
+void CustomLcdDisplay::IdleTimerCb(lv_timer_t* t) {
+    auto* self = static_cast<CustomLcdDisplay*>(lv_timer_get_user_data(t));
+    if (self != nullptr) {
+        self->UpdateIdleScreen();
+    }
+}
+
+// 双击 KEY 调音量：居中黑卡点亮前 N 格（20→1格 … 100→5格），~2.5s 后自动隐。
+// 从按键任务调用 → 必须持显示锁；VolTimerCb 跑在 LVGL task（已持锁）不再加锁。
+void CustomLcdDisplay::ShowVolume(int pct) {
+    DisplayLockGuard lock(this);
+    if (vol_popup_ == nullptr) {
+        return;
+    }
+    int lvl = (pct + 19) / 20;            // 20→1, 40→2, 60→3, 80→4, 100→5
+    if (lvl < 1) lvl = 1;
+    if (lvl > 5) lvl = 5;
+    for (int i = 0; i < 5; i++) {
+        lv_obj_set_style_bg_opa(vol_segs_[i], i < lvl ? LV_OPA_COVER : LV_OPA_TRANSP, 0);
+    }
+    lv_obj_remove_flag(vol_popup_, LV_OBJ_FLAG_HIDDEN);
+    lv_obj_move_foreground(vol_popup_);   // 压在待命屏/对话之上
+    if (vol_timer_ == nullptr) {
+        vol_timer_ = lv_timer_create(VolTimerCb, 2500, this);
+    } else {
+        lv_timer_reset(vol_timer_);       // 2.5s 内再调一次 → 续命
+        lv_timer_resume(vol_timer_);
+    }
+}
+
+void CustomLcdDisplay::VolTimerCb(lv_timer_t* t) {
+    auto* self = static_cast<CustomLcdDisplay*>(lv_timer_get_user_data(t));
+    if (self != nullptr && self->vol_popup_ != nullptr) {
+        lv_obj_add_flag(self->vol_popup_, LV_OBJ_FLAG_HIDDEN);
+    }
+    lv_timer_pause(t);   // 一次性：隐藏后停，下次 ShowVolume 再 reset+resume
+}
+
+// KEY 单击暂停/恢复：居中「⏸ 暂停」卡显/隐，常驻到再按（设备本地态，与桥 paused 逐次同步）。
+void CustomLcdDisplay::ShowPause(bool on) {
+    DisplayLockGuard lock(this);
+    if (pause_popup_ == nullptr) {
+        return;
+    }
+    if (on) {
+        lv_obj_remove_flag(pause_popup_, LV_OBJ_FLAG_HIDDEN);
+        lv_obj_move_foreground(pause_popup_);   // 压在待命屏/对话/音量条之上
+    } else {
+        lv_obj_add_flag(pause_popup_, LV_OBJ_FLAG_HIDDEN);
+    }
+}
+
+// 服务器推 alert(提醒到点)/系统通知：居中黑卡显文字，duration_ms 后自动隐。
+// 压在待命屏之上 → 暖待命时钟屏上也能看见提醒内容。同名再调=换文+续命。
+void CustomLcdDisplay::ShowNotification(const char* notification, int duration_ms) {
+    DisplayLockGuard lock(this);
+    if (notify_popup_ == nullptr || notify_msg_label_ == nullptr) {
+        return;
+    }
+    const lv_font_t* cf = CommonFont16();   // 中文全字集(assets 就绪后)，替掉缺字的 basic
+    if (cf != nullptr) {
+        lv_obj_set_style_text_font(notify_msg_label_, cf, 0);
+    }
+    lv_label_set_text(notify_msg_label_, notification ? notification : "");
+    lv_obj_remove_flag(notify_popup_, LV_OBJ_FLAG_HIDDEN);
+    lv_obj_move_foreground(notify_popup_);   // 压在待命屏/对话之上
+    int dur = duration_ms > 0 ? duration_ms : 3000;
+    if (notify_timer_ == nullptr) {
+        notify_timer_ = lv_timer_create(NotifyTimerCb, dur, this);
+    } else {
+        lv_timer_set_period(notify_timer_, dur);
+        lv_timer_reset(notify_timer_);
+        lv_timer_resume(notify_timer_);
+    }
+}
+
+void CustomLcdDisplay::NotifyTimerCb(lv_timer_t* t) {
+    auto* self = static_cast<CustomLcdDisplay*>(lv_timer_get_user_data(t));
+    if (self != nullptr && self->notify_popup_ != nullptr) {
+        lv_obj_add_flag(self->notify_popup_, LV_OBJ_FLAG_HIDDEN);
+    }
+    lv_timer_pause(t);   // 一次性：隐藏后停，下次 ShowNotification 再 reset+resume
+}
+
+// 提醒到点：反白全屏接管(status 小字 + message 大字，居中)，~15s 自动隐。
+void CustomLcdDisplay::ShowReminderAlert(const char* status, const char* message) {
+    DisplayLockGuard lock(this);
+    if (alert_screen_ == nullptr) {
+        return;
+    }
+    const lv_font_t* cf20 = CommonFont20();   // status 用 20px
+    const lv_font_t* cf30 = CommonFont30();   // message 用 30px(全字集,避免 app 内 basic 30px 缺字)
+    if (cf20 != nullptr) lv_obj_set_style_text_font(alert_status_lbl_, cf20, 0);
+    if (cf30 != nullptr) lv_obj_set_style_text_font(alert_msg_lbl_, cf30, 0);
+    lv_label_set_text(alert_status_lbl_, (status && *status) ? status : "提醒");
+    lv_label_set_text(alert_msg_lbl_, (message && *message) ? message : "");
+    lv_obj_remove_flag(alert_screen_, LV_OBJ_FLAG_HIDDEN);
+    lv_obj_move_foreground(alert_screen_);   // 压在时钟/对话/浮层之上
+    if (alert_screen_timer_ == nullptr) {
+        alert_screen_timer_ = lv_timer_create(AlertScreenTimerCb, 15000, this);
+    } else {
+        lv_timer_set_period(alert_screen_timer_, 15000);
+        lv_timer_reset(alert_screen_timer_);
+        lv_timer_resume(alert_screen_timer_);
+    }
+}
+
+void CustomLcdDisplay::AlertScreenTimerCb(lv_timer_t* t) {
+    auto* self = static_cast<CustomLcdDisplay*>(lv_timer_get_user_data(t));
+    if (self != nullptr && self->alert_screen_ != nullptr) {
+        lv_obj_add_flag(self->alert_screen_, LV_OBJ_FLAG_HIDDEN);
+    }
+    lv_timer_pause(t);   // 一次性
+}
+
+// 后端推「接下来」议程(提醒+待办，已预格式化多行)：刷新待命屏下半区。值没变不刷(反射屏防瞎刷)。
+void CustomLcdDisplay::SetAgenda(const char* reminders, const char* todos) {
+    DisplayLockGuard lock(this);
+    if (idle_rem_body_ == nullptr || idle_todo_body_ == nullptr) {
+        return;
+    }
+    const char* r = (reminders != nullptr && *reminders) ? reminders : "无";
+    const char* d = (todos != nullptr && *todos) ? todos : "无";
+    char combined[256];
+    snprintf(combined, sizeof(combined), "%s\x01%s", r, d);
+    if (strcmp(combined, idle_last_agenda_) == 0) {   // 值没变就不刷(反射屏防瞎刷)
+        return;
+    }
+    strncpy(idle_last_agenda_, combined, sizeof(idle_last_agenda_) - 1);
+    idle_last_agenda_[sizeof(idle_last_agenda_) - 1] = '\0';
+    lv_label_set_text(idle_rem_body_, r);
+    lv_label_set_text(idle_todo_body_, d);
+}
