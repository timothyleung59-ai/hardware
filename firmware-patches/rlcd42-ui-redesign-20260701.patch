+    struct { lv_obj_t** lbl; lv_obj_t** body; const char* tag; const char* ph; } secs[] = {
+        { &idle_rem_lbl_,  &idle_rem_body_,  "提醒：", "• 18:30 收衣服\n• 20:00 吃药" },
+        { &idle_todo_lbl_, &idle_todo_body_, "待办：", "• 交季度报告\n• 买牛奶" },
