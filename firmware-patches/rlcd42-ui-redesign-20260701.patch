+    lv_obj_set_size(tr, LV_SIZE_CONTENT, LV_SIZE_CONTENT);
+    lv_obj_set_style_bg_opa(tr, LV_OPA_TRANSP, 0);
+    lv_obj_set_style_border_width(tr, 0, 0);
+    lv_obj_set_style_pad_all(tr, 0, 0);
