+    lv_label_set_text(idle_env_label_, "");
+    lv_obj_set_style_text_font(idle_env_label_, small_font, 0);
+    lv_obj_set_style_text_color(idle_env_label_, black, 0);
+    lv_obj_align(idle_env_label_, LV_ALIGN_TOP_RIGHT, -16, 80);
+
+    /* 中线分隔（与顶线同粗 2px） */
+    lv_obj_t* idle_div = lv_obj_create(idle_screen_);
+    lv_obj_set_size(idle_div, LV_HOR_RES - 24, 2);
+    lv_obj_set_style_radius(idle_div, 0, 0);
+    lv_obj_set_style_bg_color(idle_div, black, 0);
+    lv_obj_set_style_bg_opa(idle_div, LV_OPA_COVER, 0);
+    lv_obj_set_style_border_width(idle_div, 0, 0);
+    lv_obj_remove_flag(idle_div, LV_OBJ_FLAG_SCROLLABLE);
+    lv_obj_align(idle_div, LV_ALIGN_TOP_MID, 0, 118);
+
+    /* 下半区：提醒 / 待办 两分区。每区 = [区标签 | 编号列表]，列表与标签顶对齐 →
+       「2、」自然缩进对齐在「1、」下面(不靠空格)。flex 列自动堆叠；20px common(占位，待 SetAgenda 覆盖)。*/
+    lv_obj_t* agenda = lv_obj_create(idle_screen_);
