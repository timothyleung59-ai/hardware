+// 字幕：当前句大字，旧句移到上方小字（替代 web 的"淡显"——1-bit 没灰阶，用字号层次）
+void CustomLcdDisplay::SetChatMessage(const char* role, const char* content) {
+    DisplayLockGuard lock(this);
+    if (chat_message_label_ == nullptr) {
+        return;
+    }
+    if (content == nullptr || content[0] == '\0') {
+        return;
+    }
+    // 首次（此刻 assets 已加载，SetupUI 时还没）把小字也换成 16px common 全字集——
+    // 否则"上句/本节课/状态"等任意文字落在 app 内嵌的 basic 子集上会缺字。
+    if (!conv_small_font_applied_) {
+        const lv_font_t* cf = CommonFont16();
+        if (cf != nullptr) {
+            lv_obj_t* small_labels[] = {prev_label_, topic_label_, who_label_,
+                                        status_label_, notification_label_};
+            for (auto lbl : small_labels) {
+                if (lbl != nullptr) {
+                    lv_obj_set_style_text_font(lbl, cf, 0);
+                }
+            }
+            conv_small_font_applied_ = true;
+        }
+    }
+    if (prev_label_ != nullptr) {
+        const char* cur = lv_label_get_text(chat_message_label_);
+        lv_label_set_text(prev_label_, (cur != nullptr) ? cur : "");
+    }
+    // 用当前主题字体——assets 在"刷新主题"时把 common 全字集 fonts.bin 设成了主题字体；
+    // SetupUI 时捕获的是 basic 内置精简子集（张老师任意文字会缺字，照片实证）。
+    auto theme = static_cast<LvglTheme*>(current_theme_);
+    if (theme != nullptr && theme->text_font() != nullptr) {
+        lv_obj_set_style_text_font(chat_message_label_, theme->text_font()->font(), 0);
+    }
+    lv_label_set_text(chat_message_label_, content);
+}
