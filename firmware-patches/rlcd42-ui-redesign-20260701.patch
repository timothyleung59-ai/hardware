+    lv_obj_set_style_pad_all(box, 0, 0);
+    lv_obj_set_style_pad_column(box, 0, 0);
+    lv_obj_set_flex_flow(box, LV_FLEX_FLOW_ROW);
+    lv_obj_set_flex_align(box, LV_FLEX_ALIGN_START, LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER);
+    lv_obj_remove_flag(box, LV_OBJ_FLAG_SCROLLABLE);
+
+    lv_obj_t* bat = lv_obj_create(box);
+    lv_obj_set_size(bat, 28, 16);
+    lv_obj_set_style_radius(bat, 2, 0);
+    lv_obj_set_style_pad_all(bat, 2, 0);
+    lv_obj_set_style_border_width(bat, 2, 0);
+    lv_obj_set_style_border_color(bat, black, 0);
+    lv_obj_set_style_bg_color(bat, white, 0);
+    lv_obj_set_style_bg_opa(bat, LV_OPA_COVER, 0);
+    lv_obj_remove_flag(bat, LV_OBJ_FLAG_SCROLLABLE);
+
+    lv_obj_t* fill = lv_obj_create(bat);                  // 内容区 = 28-2*(2框+2pad)=20 宽, 8 高
+    lv_obj_set_style_radius(fill, 0, 0);
+    lv_obj_set_style_border_width(fill, 0, 0);
+    lv_obj_set_style_pad_all(fill, 0, 0);
+    lv_obj_set_style_bg_color(fill, black, 0);
+    lv_obj_set_style_bg_opa(fill, LV_OPA_COVER, 0);
+    lv_obj_set_height(fill, 8);
+    lv_obj_set_width(fill, 1);
+    lv_obj_align(fill, LV_ALIGN_LEFT_MID, 0, 0);
+
+    lv_obj_t* nub = lv_obj_create(box);                   // 正极小帽
+    lv_obj_set_size(nub, 3, 7);
+    lv_obj_set_style_radius(nub, 0, 0);
+    lv_obj_set_style_border_width(nub, 0, 0);
+    lv_obj_set_style_pad_all(nub, 0, 0);
+    lv_obj_set_style_bg_color(nub, black, 0);
+    lv_obj_set_style_bg_opa(nub, LV_OPA_COVER, 0);
+    lv_obj_set_style_margin_left(nub, 1, 0);
+
+    *out_fill = fill;
+    return box;
+}
