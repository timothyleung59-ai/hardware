+// SHTC3（0x70，与音频 codec 共用 I2C 总线）：唤醒 → 测量(T先/普通模式/不拉伸时钟) → 读6字节 → 睡眠。
+// idle 时每 ~30s 读一次；I2C 新驱动按总线串行、线程安全，且 idle 时 codec 无 I2C 流量，无争用。
+bool CustomLcdDisplay::ReadShtc3(float& temp_c, float& humi) {
+    if (i2c_bus_ == nullptr) {
+        return false;
+    }
+    if (shtc3_dev_ == nullptr) {
+        i2c_device_config_t dc = {};
+        dc.dev_addr_length = I2C_ADDR_BIT_LEN_7;
+        dc.device_address = 0x70;
+        dc.scl_speed_hz = 100000;
+        if (i2c_master_bus_add_device(i2c_bus_, &dc, &shtc3_dev_) != ESP_OK) {
+            shtc3_dev_ = nullptr;
+            return false;
+        }
+    }
+    // 不拉伸时钟(0x7866)+手动延时+分开读。两个实测坑：
+    // 1) 拉伸模式(0x7CA2,transmit_receive)会让传感器转换时拉住 SCL 超过 ESP32 容忍度
+    //    →"clear bus failed"→ESP_ERR_INVALID_STATE，100% 失败，别用。
+    // 2) 开机头 ~10s 音频 codec(ES8311/ES7210)在同一条 I2C 上初始化抢总线，这里 meas/read
+    //    报 INVALID_STATE；codec 初始化完(~10s)立刻恢复。靠上层 idle_env_ok_ 每秒重试自愈。
+    uint8_t wake[2] = {0x35, 0x17};                       // wakeup
+    if (i2c_master_transmit(shtc3_dev_, wake, 2, 50) != ESP_OK) {
+        return false;
+    }
+    vTaskDelay(pdMS_TO_TICKS(1));                          // 唤醒需 >240us
+    uint8_t meas[2] = {0x78, 0x66};                       // 测量：T 先 / 普通模式 / 不拉伸时钟
+    if (i2c_master_transmit(shtc3_dev_, meas, 2, 50) != ESP_OK) {
+        return false;
+    }
+    vTaskDelay(pdMS_TO_TICKS(15));                         // 普通模式测量最长 ~12.1ms
+    uint8_t rx[6] = {0};
+    esp_err_t r = i2c_master_receive(shtc3_dev_, rx, 6, 50);
+    uint8_t sleep_cmd[2] = {0xB0, 0x98};                  // sleep（省电）
+    i2c_master_transmit(shtc3_dev_, sleep_cmd, 2, 50);
+    if (r != ESP_OK) {
+        return false;
+    }
+    uint16_t raw_t = ((uint16_t)rx[0] << 8) | rx[1];
+    uint16_t raw_h = ((uint16_t)rx[3] << 8) | rx[4];
+    temp_c = -45.0f + 175.0f * (float)raw_t / 65535.0f;
+    humi   = 100.0f * (float)raw_h / 65535.0f;
+    return true;
+}
+
+// 3 根升序实心信号格（细弧字形在 1-bit 硬阈值屏会被吃掉、只剩中点；实心条/轴对齐边框锐利）。
+// 返回容器供父级 flex 摆放，out_bars 接收 3 个 bar（由 SetSignalBars 按档位点亮）。
+lv_obj_t* CustomLcdDisplay::MakeSignalBars(lv_obj_t* parent, lv_obj_t* out_bars[3]) {
+    lv_color_t black = lv_color_black();
+    lv_obj_t* box = lv_obj_create(parent);
+    lv_obj_set_size(box, LV_SIZE_CONTENT, 14);
+    lv_obj_set_style_bg_opa(box, LV_OPA_TRANSP, 0);
+    lv_obj_set_style_border_width(box, 0, 0);
+    lv_obj_set_style_pad_all(box, 0, 0);
+    lv_obj_set_style_pad_column(box, 2, 0);
+    lv_obj_set_flex_flow(box, LV_FLEX_FLOW_ROW);
+    lv_obj_set_flex_align(box, LV_FLEX_ALIGN_START, LV_FLEX_ALIGN_END, LV_FLEX_ALIGN_END);  // 底对齐
+    lv_obj_remove_flag(box, LV_OBJ_FLAG_SCROLLABLE);
+    static const int BAR_H[3] = {6, 10, 14};
+    for (int i = 0; i < 3; i++) {
+        lv_obj_t* b = lv_obj_create(box);
+        lv_obj_set_size(b, 4, BAR_H[i]);
+        lv_obj_set_style_radius(b, 0, 0);
+        lv_obj_set_style_pad_all(b, 0, 0);
+        lv_obj_set_style_border_width(b, 1, 0);          // 空格=黑框白底；轴对齐边框在 1-bit 屏不糊
+        lv_obj_set_style_border_color(b, black, 0);
+        lv_obj_set_style_bg_color(b, black, 0);
+        lv_obj_set_style_bg_opa(b, LV_OPA_TRANSP, 0);    // 默认空，由 SetSignalBars 按档位点亮
+        lv_obj_remove_flag(b, LV_OBJ_FLAG_SCROLLABLE);
+        out_bars[i] = b;
+    }
+    return box;
+}
